DATABASE_URL="file:./dev.db"
PORT=4000
CUSTOS_JWT_SECRET="change-me-in-production"
CUSTOS_INTERNAL_SECRET="internal-dev-secret"
# When true, user APIs work without JWT using the first user in DB (local demo only).
CUSTOS_ALLOW_UNAUTHENTICATED_DEMO="true"
# Optional: sync invoice extract (custos_agents/invoice) — POST multipart /extract
CUSTOS_INVOICE_AGENT_URL="http://localhost:4001/extract"
# Optional: richer Invoice Copilot chat (POST /api/invoice/chat-turn). Without this, heuristics still work.
# OPENAI_API_KEY="sk-..."
# CUSTOS_INVOICE_CHAT_MODEL="gpt-4o-mini"
# Optional: event production planner (custos_agents/event_production) — POST JSON /plan
# CUSTOS_EVENT_AGENT_URL="http://localhost:4002/plan"

# Stripe (test keys for wallet top-ups, Connect transfers, and destination charges)
STRIPE_SECRET_KEY="sk_test_..."
# Prefund wallets: auto payout uses stripe.transfers to payee acct_… (platform needs available balance).
# connect_destination wallets: charges the saved card per payout with transfer_data.destination (no ledger debit).
# Optional platform fee on destination charges (cents); must be < payout amount.
# CUSTOS_STRIPE_APPLICATION_FEE_CENTS="0"
# Dev-only: allow POST /api/wallets/:id/fund manual balance bump when spendMode is STRIPE_TEST
CUSTOS_ALLOW_MANUAL_FUND="false"
# Manual treasury credit: POST /api/wallets/:id/fund/carlos — set a strong secret (CUSTOS_CARLOS_ADMIN_CODE still read for legacy)
CUSTOS_CARLOS_SECRET_CODE=""

# PayPal Payouts → Venmo (sandbox by default). Requires Payouts enabled on the PayPal app + USD.
# https://developer.paypal.com/docs/payouts/standard/payouts-to-venmo/
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# Omit or set to "false" for live API base (production).
PAYPAL_SANDBOX="true"
# Optional: ms to poll batch status after create (default 20000).
# PAYPAL_PAYOUT_POLL_MS="20000"

# Trust / human-in-the-loop (agent-supplied riskScore 0–100, flags, model confidence on spend requests)
# CUSTOS_RISK_SCORE_REVIEW_THRESHOLD="65"
# CUSTOS_MODEL_CONFIDENCE_REVIEW_MAX="0.75"
