DATABASE_URL="file:./dev.db"
PORT=4000
CUSTOS_JWT_SECRET="change-me-in-production"
CUSTOS_INTERNAL_SECRET="internal-dev-secret"
# When true, user APIs work without JWT using the first user in DB (local demo only).
CUSTOS_ALLOW_UNAUTHENTICATED_DEMO="true"
# Optional: sync invoice extract (custos_agents/invoice) — POST multipart /extract
CUSTOS_INVOICE_AGENT_URL="http://localhost:4001/extract"

# Stripe (test keys for wallet top-ups and optional Connect transfers)
STRIPE_SECRET_KEY="sk_test_..."
# Auto payout uses stripe.transfers to payee acct_… — platform needs available balance and Connect onboarding.
# Dev-only: allow POST /api/wallets/:id/fund manual balance bump when spendMode is STRIPE_TEST
CUSTOS_ALLOW_MANUAL_FUND="false"
# Manual treasury credit: POST /api/wallets/:id/fund/carlos — set a strong secret (CUSTOS_CARLOS_ADMIN_CODE still read for legacy)
CUSTOS_CARLOS_SECRET_CODE=""
