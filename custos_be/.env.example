DATABASE_URL="file:./dev.db"
PORT=4000
CUSTOS_JWT_SECRET="change-me-in-production"
CUSTOS_INTERNAL_SECRET="internal-dev-secret"
# When true, user APIs work without JWT using the first user in DB (local demo only).
CUSTOS_ALLOW_UNAUTHENTICATED_DEMO="true"
# Optional: sync invoice extract (custos_agents/invoice) — POST multipart /extract
CUSTOS_INVOICE_AGENT_URL="http://localhost:4001/extract"
