generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String?
  image     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  workspaces Workspace[]
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String   @default("Default")
  spendMode          String   @default("STRIPE_TEST")
  /** BALANCE_FIRST | CARD_AT_SPEND | BOTH — UX default for how you prefer to cover spend; all funding rails stay available. */
  fundingPreference String   @default("BOTH")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallets        Wallet[]
  agents         Agent[]
  transactions   Transaction[]
  approvedPayees ApprovedPayee[]
}

model ApprovedPayee {
  id                   String   @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  displayName          String
  legalName            String?
  /** JSON string array — alternate vendor strings for auto-match */
  aliasesJson          String   @default("[]")
  defaultRail          String   @default("merchant_card")
  /** Masked hint, e.g. "Chase checking ****4521" */
  paymentInstructions  String?
  /** Stripe Connect connected account (acct_…) for automated transfers */
  stripeConnectAccountId String?
  notes                String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  transactions         Transaction[]

  @@index([workspaceId])
}

model Wallet {
  id           String        @id @default(cuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  currency     String        @default("USD")
  balanceCents Int           @default(0)
  policyJson   String
  status       String        @default("active")
  /** prefund = ledger + Stripe transfers from platform balance; connect_destination = charge saved PM per payout with transfer_data.destination */
  fundingModel String        @default("prefund")
  stripeCustomerId             String?
  stripeDefaultPaymentMethodId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agents       Agent[]
  transactions Transaction[]
}

model Agent {
  id               String        @id @default(cuid())
  workspaceId      String
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  walletId         String
  wallet           Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  templateType     String        @default("custom")
  /** Spec: agentType — category (distinct from templateType for integrations). */
  agentType        String?
  role             String        @default("requester")
  capabilitiesJson String      @default("[]")
  /** active | paused | revoked | deleted | disabled | needs_setup */
  status           String        @default("active")
  /** Monthly spend cap in cents (null = no agent-level cap). */
  monthlyAllowanceCents     Int?
  /** Amount above which human approval is required (agent-level), cents. */
  approvalThresholdCents    Int?
  /** Single-transaction ceiling in cents. */
  maxTransactionAmountCents Int?
  budgetCurrency            String @default("USD")
  vendorAllowlistJson       String @default("[]")
  vendorDenylistJson        String @default("[]")
  allowedPaymentMethodsJson String @default("[]")
  /** Max spend per calendar day (UTC start) for this agent; null = no agent daily cap */
  dailySpendLimitCents      Int?
  /** When true, spend must match an approved payee (same semantics as wallet policy flag). */
  requireApprovedPayee      Boolean @default(false)
  /** JSON array of rail ids — if non-empty, request rail must be listed (e.g. stripe_connect). */
  allowedPayoutRailsJson    String @default("[]")
  /** JSON array — if non-empty, category must match one (when category is sent). */
  allowedCategoriesJson     String @default("[]")
  /** JSON array — vendor substring hits block (merged with wallet restricted list in policy). */
  restrictedVendorsJson     String @default("[]")
  settingsJson              String @default("{}")
  metadataJson              String @default("{}")
  createdByUserId           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  apiKeys          AgentApiKey[]
  transactions     Transaction[]
}

model AgentApiKey {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  keyPrefix String    @unique
  keyHash   String
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([agentId])
}

model Transaction {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  walletId       String
  wallet         Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  amountCents    Int
  currency       String    @default("USD")
  railType       String    @default("merchant_card")
  sourceKind     String    @default("api")
  status         String
  policyResult   String?
  reviewState    String?
  recipient      String?
  vendor         String?
  category       String?
  memo           String?
  /** Why the agent initiated this spend (audit). */
  purpose        String?
  /** Structured agent context (JSON). */
  contextJson    String?
  idempotencyKey String?
  evidenceJson   String?
  /** 0–100 scale from agent; high values trigger review when above env threshold */
  riskScore      Int?
  riskFlagsJson  String?
  /** Cited policy / rule objects: [{ id, title, source?, excerpt? }] */
  citedRulesJson String?
  /** Agent decision trace: { summary, reasoning?, modelConfidence? 0–1 } */
  agentDecisionJson String?
  policyEvalJson String?
  auditJson      String?
  payeeId        String?
  payee          ApprovedPayee? @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  /** not_attempted | skipped | processing | succeeded | failed | unsupported_rail */
  payoutStatus   String?
  payoutProvider String?
  payoutExternalId String?
  payoutError    String?
  payoutAttemptedAt DateTime?
  settledAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, idempotencyKey])
}

model UploadedFile {
  id        String   @id @default(cuid())
  path      String
  mimeType  String?
  createdAt DateTime @default(now())
}

/** Idempotent record of Stripe-funded wallet top-ups (webhook). */
model StripePaymentLedger {
  id              String   @id @default(cuid())
  paymentIntentId String   @unique
  walletId        String
  workspaceId     String
  amountCents     Int
  currency        String   @default("usd")
  createdAt       DateTime @default(now())
}
