NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# "true" = real Google OAuth on /login. Omit or "false" skips login (dev shortcut to /overview).
NEXT_PUBLIC_ENABLE_AUTH="true"

# Point the browser at custos_be for API calls from the dashboard.
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Server-only: used on Google sign-in to provision user/workspace/wallet/agent (must be reachable from Next.js).
CUSTOS_API_URL="http://localhost:4000"
# Must match custos_be CUSTOS_INTERNAL_SECRET
CUSTOS_INTERNAL_SECRET="internal-dev-secret"

# Stripe — same secret key as custos_be for webhook route; publishable key for Elements
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
